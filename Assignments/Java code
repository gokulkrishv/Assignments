import java.util.Scanner;

public class RetailStoreCalculator {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Input item price, quantity, sales tax rate, and discount rate
        System.out.print("Enter item price (in cents): ");
        short itemPriceCents = scanner.nextShort();

        System.out.print("Enter item quantity: ");
        int quantity = scanner.nextInt();

        System.out.print("Enter sales tax rate (in percentage): ");
        float salesTaxRate = scanner.nextFloat();

        System.out.print("Enter discount rate (in percentage): ");
        float discountRate = scanner.nextFloat();

        // Calculate the total price before tax and discount
        int totalPriceBeforeTaxAndDiscount = itemPriceCents * quantity;

        // Calculate the sales tax amount
        float salesTaxAmount = totalPriceBeforeTaxAndDiscount * (salesTaxRate / 100);

        // Calculate the discount amount
        float discountAmount = totalPriceBeforeTaxAndDiscount * (discountRate / 100);

        // Calculate the final total price
        double finalTotalPrice = totalPriceBeforeTaxAndDiscount + salesTaxAmount - discountAmount;

        // Print the final total price with two decimal places
        System.out.printf("Final total price: %.2f\n", finalTotalPrice);

        scanner.close();
    }
}